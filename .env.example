# Neptu.ai Environment Variables
# Copy this file to .env and fill in your values
# Single source of truth - all apps read from this file

# ─── Dynamic.xyz ───────────────────────────────────────
VITE_DYNAMIC_ENVIRONMENT_ID=
# Same ID used by API for JWT verification via JWKS
DYNAMIC_ENVIRONMENT_ID=

# ─── PostgreSQL Database ───────────────────────────────
DATABASE_URL=postgresql://neptu:neptu@localhost:5432/neptu

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Solana Network (localnet | devnet | mainnet) ─────
# Change this single value to switch all apps
SOLANA_NETWORK=devnet

# ─── API Server ────────────────────────────────────────
API_URL=http://localhost:3000
PORT=3000
JWT_SECRET=
ADMIN_WALLET_ADDRESS=
WORKER_URL=http://localhost:8080

# ─── Azure Speech (Voice Oracle - STT/TTS) ────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ─── Azure OpenAI (Worker - Oracle AI) ────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# ─── Market Data ───────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=

# ─── Notion MCP ───────────────────────────────────────
NOTION_TOKEN=
